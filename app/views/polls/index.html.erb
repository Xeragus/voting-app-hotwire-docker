<div class="mb-10">
  <h1 class="text-4xl font-bold text-center">🗳️ Available Polls</h1>
</div>

<div class="flex flex-col items-center justify-center space-y-4 w-3xl text-center w-full">
  <% @polls.each do |poll| %>
    <%= link_to poll_path(poll), class: "block" do %>
      <div class="w-full border border-white/10 bg-gray-200 rounded-xl p-6 shadow hover:bg-gray-300 transition cursor-pointer">
        <h2 class="text-xl font-semibold text-blue-400 group-hover:text-blue-300 transition">
          <%= poll.question %>
        </h2>
        <p class="mt-2 text-sm text-gray-400">
          <%= pluralize(poll.options.sum(&:vote_count), 'vote') %> so far
        </p>
      </div>
    <% end %>
  <% end %>
</div>
