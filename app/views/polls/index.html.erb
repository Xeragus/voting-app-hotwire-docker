<div class="mb-4">
  <h1 class="display-4 text-center">🗳️ Available Polls</h1>
</div>

<div class="container card">
  <div class="row justify-content-center">
    <% @polls.each do |poll| %>
      <div class="col-md-8 mb-4">
        <%= link_to poll_path(poll), class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm h-100 bg-light">
            <div class="card-body">
              <h2 class="h5 text-primary mb-2"><%= poll.question %></h2>
              <p class="text-muted small mb-0">
                <%= pluralize(poll.options.sum(&:vote_count), 'vote') %> so far
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
