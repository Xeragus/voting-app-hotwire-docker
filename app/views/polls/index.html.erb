<% if @polls.present? %>
  <div class="mb-4 mt-5">
    <h1 class="display-4 text-center">🗳️ Available Polls</h1>
  </div>

  <div class="container polls mt-5">
    <div class="row justify-content-center">
      <% @polls.each do |poll| %>
        <div class="col-md-8 mb-4">
          <%= link_to poll_path(poll), class: "text-decoration-none" do %>
            <div class="card border-0 shadow-sm h-100 bg-light hover-shadow transition" style="cursor: pointer;">
              <div class="hover-gray p-4 rounded">
                <h2 class="h5 text-primary mb-2"><%= poll.question %></h2>
                <p class="text-muted small mb-0">
                  <%= pluralize(poll.options.sum(&:vote_count), 'vote') %> so far
                </p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
<div class="mb-4 mt-5">
    <h1 class="display-4 text-center">🗳️ No available polls, please run the seeder</h1>
  </div>
<% end %>